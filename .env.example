# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ── Mem0 memory backend ───────────────────────────────────────────────────────
# Choose ONE option; leave both blank to use the in-process mock (dev only).

# Option A — Self-hosted Mem0 / OpenMemory server
MEM0_SERVER_URL=http://localhost:8765

# Option B — Mem0 cloud (https://mem0.ai)
# MEM0_API_KEY=m0-...

# Prefix prepended to device_id to form the Mem0 user_id.
# Default: xiaozhi_ → user_id = xiaozhi_device_10_0_0_117
MEM0_USER_ID_PREFIX=xiaozhi_

# ── WebSocket server ──────────────────────────────────────────────────────────
WS_HOST=0.0.0.0
WS_PORT=8001

# ── Audio / ASR tuning ────────────────────────────────────────────────────────
# How many Opus frames to buffer before forcing a transcription (realtime mode)
MAX_LISTEN_FRAMES=25
# Seconds of silence before auto-processing buffered audio (auto mode)
SILENCE_TIMEOUT=1.5
