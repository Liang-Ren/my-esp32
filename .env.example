# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Hard deadline for the OpenAI HTTP call (seconds). Increase if you see
# frequent timeouts on slow networks; reduce for snappier fallback.
LLM_TIMEOUT=30.0

# ── Mem0 memory backend ───────────────────────────────────────────────────────
# Choose ONE option; leave both blank to use the in-process mock (dev only).

# Option A — Self-hosted Mem0 / OpenMemory server
MEM0_SERVER_URL=http://localhost:8765

# Option B — Mem0 cloud (https://mem0.ai)
# MEM0_API_KEY=m0-...

# Prefix prepended to device_id to form the Mem0 user_id.
# Default: xiaozhi_ → user_id = xiaozhi_device_10_0_0_117
MEM0_USER_ID_PREFIX=xiaozhi_

# How long to wait for Mem0 + SQLite reads before continuing without memory.
# Set lower (e.g. 2.0) on slow hardware to avoid perceptible latency.
MEMORY_TIMEOUT=5.0

# ── WebSocket server ──────────────────────────────────────────────────────────
WS_HOST=0.0.0.0
WS_PORT=8001

# Ping/pong keepalive (seconds). Unresponsive devices are disconnected after
# WS_PING_TIMEOUT seconds with no pong reply.
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=20

# ── Health server (HTTP) ──────────────────────────────────────────────────────
# GET /health → 200 {"status":"ok","uptime_s":N}
# GET /ready  → 200/503 {"ready":true|false}
HEALTH_PORT=8002

# ── Audio / ASR tuning ────────────────────────────────────────────────────────
# How many Opus frames to buffer before forcing a transcription (realtime mode)
MAX_LISTEN_FRAMES=25
# Seconds of silence before auto-processing buffered audio (auto mode)
SILENCE_TIMEOUT=1.5

# ── Voice response ────────────────────────────────────────────────────────────
# Maximum characters sent to edge-tts. Longer replies are truncated at the
# last sentence boundary. 150 is comfortable for a quick voice reply;
# 300 is the default upper limit for demo use.
MAX_VOICE_REPLY_CHARS=300
